# Environment Mode (LOCAL or CLOUD)
ENV=CLOUD

# Qdrant Vector Database (Local)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_CLUSTER_NAME=rag_project_cluster

# Qdrant Cloud (Use when ENV=CLOUD)
QDRANT_CLOUD_URL=https://your-cluster-id.europe-west3-0.gcp.cloud.qdrant.io
QDRANT_CLOUD_API_KEY=your_qdrant_cloud_api_key_here

# Supabase Database
SUPABASE_URL=postgresql://postgres.[ref]:[password]@[host]:6543/postgres

# Supabase S3 Storage (for document uploads)
SUPABASE_S3_BUCKET=RAG_INGEST_DOCS
SUPABASE_S3_ACCESS_KEY_ID=your_supabase_s3_access_key_id
SUPABASE_S3_SECRET_ACCESS_KEY=your_supabase_s3_secret_key
SUPABASE_S3_ENDPOINT=https://your-project.storage.supabase.co/storage/v1/s3

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# Cohere
COHERE_API_KEY=your_cohere_api_key_here

# Backend URL (for CORS and redirects)
# LOCAL: http://localhost:8080
# CLOUD: https://your-backend-url.com
BACKEND_URL=http://localhost:8080
APP_NAME=RAG Pipeline API
DEBUG=true
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
DEFAULT_EMBEDDING_MODEL=gemini-embedding-001
DEFAULT_LLM_MODEL=gpt-3.5-turbo
